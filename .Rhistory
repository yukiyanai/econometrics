fit_3,
lwdOuter = 1,       # 95%信頼区間を表示する線分の太さ
intercept = FALSE,  # 切片は興味の対象ではないので非表示
title = "係数の推定値：応答変数は得票率（％）",
xlab = "係数の推定値",
ylab = "説明変数",
newNames = c(experience = "議員経験",　expm = "選挙費用（100万円）"))
plot(plt_fit3)
