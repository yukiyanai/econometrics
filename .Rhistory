sim_mc <- function(N = 100, K = 1, alpha = 0.05) {
X <- matrix(rnorm(N * K, mean = 0, sd = 2), ncol = K)
y <- rnorm(N)
fit <- lm(y ~ X)
pv <- tidy(fit) |>
filter(term != "(Intercept)") |>
