dplyr::select(voteshare, expm, experience)
summary(HR09)
apply(HR09, MARGIN = 2, FUN = sd)
HR09 |>
summarize(voteshare_sd = sd(voteshare),
expm_sd = sd(exmp),
experience_sd = sd(experience))
HR09 |>
summarize(voteshare_sd = sd(voteshare),
expm_sd = sd(expm),
experience_sd = sd(experience))
